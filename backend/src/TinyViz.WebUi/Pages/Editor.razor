@page "/Editor"
@rendermode InteractiveServer

<DockView class="dock-editor" Name="Editor">
    <DockContent Type="DockContentType.Row">
        <DockContent Type="DockContentType.Column">
            <DockComponent Title="Yaml Editor">
                <CodeEditor Value="@Code" Language="yaml" ShowLineNo="true" Theme="vs-dark"/>
            </DockComponent>
        </DockContent>

        <DockContent Type="DockContentType.Column">
            <DockComponent Title="Preview">
                Preview
            </DockComponent>
        </DockContent>
    </DockContent>

    @* <DockContent Type="DockContentType.Row"> *@
    @*     Console *@
    @* </DockContent> *@
</DockView>

@code {

    private string Code { get; set; }
        = """
          global:
            style:
          dataSources:
            prom:
              type: prometheus
              baseUrl: 'prom.acaad.dev'
              auth: null
          plots:
            power_consumption:
              plot:
                type: scatter
              dataSource:
                type: range
                backend: prom
                timeRange: now - 6h
                query: |
                  power_consumption{device="audio-interface"}

          """;

}
